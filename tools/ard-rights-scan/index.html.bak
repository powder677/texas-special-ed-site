   <main style="flex:1; background-color: #f8fafc; padding: 40px 20px;">
      <div style="max-width: 820px; margin: 0 auto;">

         <div style="text-align: center; margin-bottom: 32px;">
            <span style="display: inline-block; background: #d4af37; color: #0f172a; padding: 5px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; font-family: 'DM Sans', sans-serif;">Free AI Tool</span>
            <h1 style="font-family: 'Lora', serif; font-size: 2.5rem; color: #0a2342; margin-bottom: 16px;">
               Free ARD Rights Scan
            </h1>
            <p style="font-family: 'Source Sans 3', sans-serif; font-size: 1.1rem; color: #475569; max-width: 600px; margin: 0 auto;">
               Wondering if your school violated your rights? Answer a few questions and get an instant AI-powered analysis based on Texas Education Code and IDEA federal law.
            </p>
         </div>

         <iframe allow="clipboard-write" src="https://ard-chatbot-831148457361.us-central1.run.app" style="width: 100%; height: 850px; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 8px 30px rgba(0,0,0,0.08); background: #ffffff;" title="ARD Rights Scan Tool">
         </iframe>

         <!-- Trust line below bot -->
         <p style="text-align: center; font-family: 'Source Sans 3', sans-serif; font-size: 0.85rem; color: #94a3b8; margin-top: 16px;">
            🔒 No account required  ·  100% free  ·  Based on Texas Education Code & IDEA
         </p>

      </div>
   </main>

   <script>
      document.addEventListener('DOMContentLoaded', function() {
         const toggle = document.querySelector('.mobile-menu-toggle');
         const menu = document.querySelector('.nav-menu');
         if (toggle && menu) toggle.addEventListener('click', () => menu.classList.toggle('active'));
      });
   </script>

