const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyYVaXK8FUpzyC5ij59maP0aMF2Ww6DM5X4ChBnqJS9FxkuU0mDaGuYMx8tbEpiJX7j/exec';

document.querySelectorAll('.subscribe-form, .footer-subscribe').forEach(function(form) {
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    
    var button = form.querySelector('button[type="submit"]');
    var email = form.querySelector('input[type="email"]').value;
    var districtInput = form.querySelector('input[name="district"]');
    var district = districtInput ? districtInput.value : '';
    
    button.disabled = true;
    button.textContent = 'Sending...';
    
    fetch(GOOGLE_SCRIPT_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, district: district })
    })
    .then(function() {
      form.innerHTML = '<p style="color: green; font-weight: 600;">✓ You\'re subscribed!</p>';
    })
    .catch(function() {
      button.disabled = false;
      button.textContent = 'Subscribe';
      alert('Something went wrong. Please try again.');
    });
  });
});
</script>

<!-- Optional: Mobile Menu Toggle Script -->
<script>
document.querySelector('.mobile-menu-toggle')?.addEventListener('click', function() {
  this.classList.toggle('active');
  document.querySelector('.nav-menu')?.classList.toggle('active');
  const expanded = this.getAttribute('aria-expanded') === 'true';
  this.setAttribute('aria-expanded', !expanded);
});

// Close mobile menu when clicking outside
document.addEventListener('click', function(event) {
  const nav = document.querySelector('.navbar');
  const toggle = document.querySelector('.mobile-menu-toggle');
  if (!nav?.contains(event.target)) {
    toggle?.classList.remove('active');
    document.querySelector('.nav-menu')?.classList.remove('active');
    toggle?.setAttribute('aria-expanded', 'false');
  }
});
</script>