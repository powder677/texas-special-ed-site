<!-- ========== SCRIPTS ========== -->
<script>
// Newsletter / subscribe forms (Google Script)
var GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyYVaXK8FUpzyC5ij59maP0aMF2Ww6DM5X4ChBnqJS9FxkuU0mDaGuYMx8tbEpiJX7j/exec';

document.querySelectorAll('.subscribe-form, .footer-subscribe').forEach(function(form) {
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var button = form.querySelector('button[type="submit"]');
    var email = form.querySelector('input[type="email"]').value;
    var districtInput = form.querySelector('input[name="district"]');
    var district = districtInput ? districtInput.value : '';
    button.disabled = true;
    button.textContent = 'Sending...';
    fetch(GOOGLE_SCRIPT_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, district: district })
    })
    .then(function() {
      form.innerHTML = '<p style="color:#4caf50; font-weight:600;">&#10003; You\'re subscribed!</p>';
    })
    .catch(function() {
      button.disabled = false;
      button.textContent = 'Subscribe';
      alert('Something went wrong. Please try again.');
    });
  });
});

// Category filter
(function () {
  var buttons = document.querySelectorAll('[data-filter]');
  var featured = document.querySelector('.featured-post');
  var cards = document.querySelectorAll('.blog-card');
  var noResults = document.querySelector('.no-results');

  function filterPosts(category) {
    buttons.forEach(function(btn) {
      var isActive = btn.getAttribute('data-filter') === category;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    var visible = 0;

    if (featured) {
      var show = category === 'all' || featured.getAttribute('data-category') === category;
      featured.style.display = show ? '' : 'none';
      if (show) visible++;
    }

    cards.forEach(function(card) {
      var show = category === 'all' || card.getAttribute('data-category') === category;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  buttons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterPosts(this.getAttribute('data-filter'));
    });
  });
})();

// Mobile nav
document.addEventListener('DOMContentLoaded', function () {
  var toggle = document.querySelector('.mobile-menu-toggle');
  var menu = document.querySelector('.nav-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', function () {
      menu.classList.toggle('active');
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
    });
  }
  document.querySelectorAll('.dropdown-toggle').forEach(function (drop) {
    drop.addEventListener('click', function (e) {
      if (window.innerWidth <= 900) {
        e.preventDefault();
        this.parentElement.classList.toggle('active');
      }
    });
  });
});
</script>

</body>
