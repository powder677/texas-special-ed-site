 <script>
const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyYVaXK8FUpzyC5ij59maP0aMF2Ww6DM5X4ChBnqJS9FxkuU0mDaGuYMx8tbEpiJX7j/exec';

document.querySelectorAll('.subscribe-form, .footer-subscribe').forEach(function(form) {
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    
    var button = form.querySelector('button[type="submit"]');
    var email = form.querySelector('input[type="email"]').value;
    var districtInput = form.querySelector('input[name="district"]');
    var district = districtInput ? districtInput.value : '';
    
    button.disabled = true;
    button.textContent = 'Sending...';
    
    fetch(GOOGLE_SCRIPT_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, district: district })
    })
    .then(function() {
      form.innerHTML = '<p style="color: green; font-weight: 600;">✓ You\'re subscribed!</p>';
    })
    .catch(function() {
      button.disabled = false;
      button.textContent = 'Subscribe';
      alert('Something went wrong. Please try again.');
    });
  });
});
</script>
<script>
      (function () {
         var buttons = document.querySelectorAll('[data-filter]');
         var featured = document.querySelector('.featured-post');
         var cards = document.querySelectorAll('.blog-card');
         var grid = document.querySelector('.blog-grid');
         var noResults = document.querySelector('.no-results');

         function filterPosts(category) {
            // Update active button
            buttons.forEach(function (btn) {
               var isActive = btn.getAttribute('data-filter') === category;
               btn.classList.toggle('active', isActive);
               btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
            });

            var visibleCount = 0;

            // Filter featured post
            if (category === 'all' || featured.getAttribute('data-category') === category) {
               featured.style.display = '';
               visibleCount++;
            } else {
               featured.style.display = 'none';
            }

            // Filter cards
            cards.forEach(function (card) {
               if (category === 'all' || card.getAttribute('data-category') === category) {
                  card.style.display = '';
                  visibleCount++;
               } else {
                  card.style.display = 'none';
               }
            });

            // Show/hide no-results message
            noResults.style.display = visibleCount === 0 ? 'block' : 'none';
         }

         buttons.forEach(function (btn) {
            btn.addEventListener('click', function () {
               filterPosts(this.getAttribute('data-filter'));
            });
         });
      })();
   </script>























